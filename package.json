{
  "name": "deal-dash-monorepo",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "compass:update": "node scripts/update-compass.js",
    "dev:web": "npm run compass:update && npm run dev --workspace=apps/web",
    "dev:scrapers": "npm run start --workspace=services/scrapers"
  }
}
