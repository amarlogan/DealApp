# Supabase API Gateway
srv1603188.hstgr.cloud {
    reverse_proxy kong:8000
    log {
        output stdout
        format console
    }
}

# HuntMyDeal Production App
huntmydeal.com, www.huntmydeal.com {
    # Direct proxies for Supabase (Must come before the main app proxy)
    reverse_proxy /auth/v1/* kong:8000
    reverse_proxy /rest/v1/* kong:8000
    reverse_proxy /storage/v1/* kong:8000

    # Everything else goes to the Next.js app
    reverse_proxy huntmydeal-web:3000

    header {


        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer-when-downgrade
    }

    log {
        output stdout
        format console
    }
}
